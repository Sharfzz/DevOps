<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Financial Hub - Campus Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #f8fafc; margin: 0; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        
        /* Layout */
        .sis-container { width: 95%; max-width: 1500px; margin: 40px auto; padding: 0; display: grid; grid-template-columns: 320px 1fr; gap: 40px; align-items: start; }
        
        /* Sidebar */
        .sis-sidebar { background: white; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); text-align: center; overflow: hidden; border: 1px solid #f1f5f9; }
        .sis-sidebar-cover { background: linear-gradient(135deg, #0f172a 0%, #334155 100%); height: 120px; width: 100%; margin-bottom: -60px; }
        .sis-avatar { width: 110px; height: 110px; background: #1e293b; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40px; font-weight: bold; margin: 0 auto 16px auto; border: 6px solid white; position: relative; z-index: 2; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .sis-name { margin: 0 0 8px 0; font-size: 22px; color: #0f172a; font-weight: 700; letter-spacing: -0.5px; }
        .sis-badge { display: inline-block; background: #e0f2fe; color: #0284c7; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; margin-bottom: 24px; }
        .sis-contact-list { text-align: left; background: #f8fafc; padding: 24px; border-top: 1px solid #f1f5f9; }
        .sis-contact-item { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; color: #475569; font-size: 14px; font-weight: 500; }
        .sis-contact-item:last-child { margin-bottom: 0; }
        .sis-contact-icon { width: 18px; height: 18px; color: #64748b; }
        
        /* Main Panel & Tabs */
        .sis-main { display: flex; flex-direction: column; gap: 24px; }
        .sis-tab-header { display: flex; gap: 8px; border-bottom: 2px solid #e2e8f0; padding: 0 8px; }
        .sis-tab-btn { background: transparent; border: none; padding: 16px 24px; font-size: 15px; font-weight: 600; color: #64748b; cursor: pointer; position: relative; transition: color 0.2s; }
        .sis-tab-btn::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 100%; height: 2px; background: transparent; transition: background 0.2s; }
        .sis-tab-btn.active { color: #0f172a; }
        .sis-tab-btn.active::after { background: #0f172a; }
        .sis-tab-btn:hover:not(.active) { color: #0f172a; }
        
        .sis-tab-content { display: none; animation: fadeIn 0.3s ease-in-out; }
        .sis-tab-content.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Modern Data Cards */
        .sis-data-group { background: white; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); overflow: hidden; margin-bottom: 24px; }
        .sis-data-title { background: #f8fafc; padding: 20px 24px; margin: 0; font-size: 16px; color: #0f172a; border-bottom: 1px solid #e2e8f0; font-weight: 700; letter-spacing: -0.3px; }
        .sis-row { display: flex; align-items: center; padding: 20px 24px; border-bottom: 1px solid #f1f5f9; transition: background 0.2s; }
        .sis-row:last-child { border-bottom: none; }
        .sis-row:hover { background: #f8fafc; }
        .sis-label { width: 220px; color: #64748b; font-size: 14px; font-weight: 600; flex-shrink: 0; }
        .sis-value { color: #0f172a; font-size: 15px; font-weight: 500; }
        
        /* Security Button Override */
        .btn-danger { background: #ef4444; color: white; border: none; padding: 12px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: background 0.2s; }
        .btn-danger:hover { background: #dc2626; }
        
        .btn-primary { background: #0284c7; color: white; border: none; padding: 12px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: background 0.2s; text-decoration: none; display: inline-block; }
        .btn-primary:hover { background: #0369a1; }
        
        .amount-header { font-size: 48px; font-weight: 700; color: #0f172a; margin: 0 0 8px 0; }
        .due-date { font-size: 16px; color: #64748b; margin: 0 0 24px 0; font-weight: 500; }
        
        /* Modal Styles */
        .sis-modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.6); z-index: 100; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
        .sis-modal-overlay.active { display: flex; }
        .sis-modal-card { background: white; width: 90%; max-width: 500px; border-radius: 16px; padding: 32px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); }
        .sis-modal-title { font-size: 20px; font-weight: 700; color: #0f172a; margin-top: 0; margin-bottom: 24px; border-bottom: 1px solid #e2e8f0; padding-bottom: 12px; }
        .sis-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
        .sis-form-group { display: flex; flex-direction: column; gap: 6px; }
        .sis-form-group.full-width { grid-column: span 2; }
        .sis-input-label { font-size: 13px; font-weight: 600; color: #475569; }
        .sis-input { padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 14px; color: #0f172a; font-family: inherit; }
        .sis-input:focus { outline: none; border-color: #0284c7; box-shadow: 0 0 0 3px #e0f2fe; }
        .sis-btn-primary { background: #0f172a; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: 600; cursor: pointer; width: 100%; margin-top: 8px; }
        .sis-btn-cancel { background: white; color: #64748b; border: 1px solid #cbd5e1; padding: 10px; border-radius: 8px; font-weight: 600; cursor: pointer; width: 100%; margin-top: 8px; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="sis-container">
        
        <aside class="sis-sidebar">
            <div class="sis-sidebar-cover"></div>
            <div class="sis-avatar">
                <%= userProfile.fullName.charAt(0).toUpperCase() %>
            </div>
            <h1 class="sis-name" style="margin-top: 16px;"><%= userProfile.fullName %></h1>
            <div class="sis-badge"><%= userProfile.role %></div>
            
            <div class="sis-contact-list">
                <div class="sis-contact-item">
                    <svg class="sis-contact-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    <%= userProfile.campusEmail || 'Pending Setup' %>
                </div>
                <div class="sis-contact-item">
                    <svg class="sis-contact-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    <%= userProfile.contactMobile || 'N/A' %>
                </div>
                <div class="sis-contact-item">
                    <svg class="sis-contact-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
                    ID: <%= userProfile.campusId %>
                </div>
            </div>
        </aside>

        <main class="sis-main">
            <div class="sis-tab-header">
                <button class="sis-tab-btn active" onclick="switchTab('billing')">Billing Overview</button>
                <button class="sis-tab-btn" onclick="switchTab('payment-methods')">Payment Methods</button>
            </div>

            <div id="tab-billing" class="sis-tab-content active">
                <div class="sis-data-group" style="padding: 40px 24px; text-align: center;">
                    <h2 style="font-size: 16px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 12px 0;">Outstanding Balance</h2>
                    <div class="amount-header">$<%= userProfile.financials ? userProfile.financials.outstandingBalance.toFixed(2) : '0.00' %></div>
                    <div class="due-date">Due Date: <%= userProfile.financials ? userProfile.financials.dueDate : 'N/A' %></div>
                    
                    <% if (userProfile.financials && userProfile.financials.outstandingBalance > 0) { %>
                        <button type="button" class="btn-primary" style="padding: 14px 32px; font-size: 16px;" onclick="openModal('checkoutModal')">Pay Now</button>
                    <% } else { %>
                        <div style="display: inline-block; background: #ecfdf5; color: #10b981; padding: 12px 24px; border-radius: 8px; font-weight: 600;">
                            All settled up!
                        </div>
                    <% } %>
                </div>
            </div>

            <div id="tab-payment-methods" class="sis-tab-content">
                <div style="padding: 24px;">
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-bottom: 24px;">
                        
                        <% if (userProfile.financials.paymentMethods && userProfile.financials.paymentMethods.length > 0) { %>
                            <% userProfile.financials.paymentMethods.forEach(function(card) { %>
                                <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); color: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); position: relative;">
                                    <form action="/financial/remove-card" method="POST" style="position: absolute; top: 16px; right: 16px; margin: 0;">
                                        <input type="hidden" name="maskedNumber" value="<%= card.maskedNumber %>">
                                        <button type="submit" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: none; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 14px; transition: all 0.2s;" onmouseover="this.style.background='#ef4444'; this.style.color='white'" onmouseout="this.style.background='rgba(239, 68, 68, 0.1)'; this.style.color='#ef4444'" title="Remove Card">
                                            ✕
                                        </button>
                                    </form>
                                    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #94a3b8; margin-bottom: 4px;"><%= card.type %> CARD</div>
                                    <div style="font-size: 14px; font-weight: 600; margin-bottom: 24px;"><%= card.brand %></div>
                                    <div style="font-family: monospace; font-size: 18px; letter-spacing: 2px; margin-bottom: 12px;"><%= card.maskedNumber %></div>
                                    <div style="font-size: 11px; color: #64748b; text-align: right;">SECURELY STORED</div>
                                </div>
                            <% }); %>
                        <% } %>

                        <div onclick="openModal('addCardModal')" style="border: 2px dashed #cbd5e1; border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; cursor: pointer; min-height: 140px; transition: all 0.2s; background: transparent;" onmouseover="this.style.borderColor='#0f172a'; this.style.backgroundColor='#f8fafc';" onmouseout="this.style.borderColor='#cbd5e1'; this.style.backgroundColor='transparent';">
                            <div style="font-size: 24px; color: #0f172a; margin-bottom: 8px;">+</div>
                            <div style="font-size: 14px; font-weight: 600; color: #475569;">Add New Card</div>
                        </div>

                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modals -->
    <div id="addCardModal" class="sis-modal-overlay">
        <div class="sis-modal-card">
            <h3 class="sis-modal-title">Add Payment Method</h3>
            <form action="/financial/add-card" method="POST" id="addCardForm">
                <div style="display: flex; gap: 16px; margin-bottom: 20px;">
                    <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #0f172a; cursor: pointer;">
                        <input type="radio" name="cardType" value="Credit" checked> Credit Card
                    </label>
                    <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #0f172a; cursor: pointer;">
                        <input type="radio" name="cardType" value="Debit"> Debit Card
                    </label>
                </div>

                <div class="sis-form-grid">
                    <div class="sis-form-group"><label class="sis-input-label">First Name</label><input type="text" name="firstName" class="sis-input" placeholder="Albert" required></div>
                    <div class="sis-form-group"><label class="sis-input-label">Last Name</label><input type="text" name="lastName" class="sis-input" placeholder="Einstein" required></div>
                    <div class="sis-form-group full-width"><label class="sis-input-label">Card Number</label><input type="text" name="cardNumber" id="cardNumberInput" class="sis-input" placeholder="0000 0000 0000 0000" pattern=".{19}" title="Card number must be exactly 16 digits" maxlength="19" required></div>
                    <div class="sis-form-group"><label class="sis-input-label">Expiration Date</label><input type="text" name="expDate" id="cardExpiryInput" class="sis-input" placeholder="MM/YY" maxlength="5" required></div>
                    <div class="sis-form-group"><label class="sis-input-label">Security Code (CVV)</label><input type="text" name="cvv" class="sis-input" placeholder="123" maxlength="4" required></div>
                    <div class="sis-form-group full-width"><label class="sis-input-label">Postal Code</label><input type="text" name="postalCode" class="sis-input" placeholder="Singapore 123456" required></div>
                </div>
                <button type="submit" class="sis-btn-primary">Save Card Details</button>
                <button type="button" class="sis-btn-cancel" onclick="closeModal('addCardModal')">Cancel</button>
            </form>
        </div>
    </div>

    <div id="checkoutModal" class="sis-modal-overlay">
        <div class="sis-modal-card">
            <h3 class="sis-modal-title">Select Payment Method</h3>
            <form action="/financial/pay" method="POST" style="margin:0;">
                <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
                    
                    <% if (userProfile.financials.paymentMethods && userProfile.financials.paymentMethods.length > 0) { %>
                        <% userProfile.financials.paymentMethods.forEach(function(card, index) { %>
                            <label style="display: flex; align-items: center; gap: 10px; border: 1px solid #cbd5e1; padding: 12px; border-radius: 8px; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
                                <input type="radio" name="paymentType" value="card_<%= index %>" <%= index === 0 ? 'checked' : '' %>> 
                                <span style="font-weight: 600; color: #0f172a;"><%= card.type %> Card</span> 
                                <span style="color: #64748b; font-size: 14px;">ending in <%= card.maskedNumber.slice(-4) %></span>
                            </label>
                        <% }); %>
                    <% } else { %>
                        <div style="color: #ef4444; font-size: 13px; font-weight: 600; margin-bottom: 8px;">No saved cards found.</div>
                    <% } %>


                </div>
                <button type="submit" class="sis-btn-primary">Confirm Payment</button>
                <button class="sis-btn-cancel" type="button" onclick="closeModal('checkoutModal')">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        // Modal Logic
        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        // Auto-formatting card number
        document.getElementById('cardNumberInput').addEventListener('input', function (e) {
            let target = e.target;
            let val = target.value.replace(/\D/g, ''); // Strip non-numeric characters
            target.value = val.replace(/(.{4})/g, '$1 ').trim(); // Add space every 4 digits
        });

        document.getElementById('cardExpiryInput').addEventListener('input', function (e) {
            let target = e.target;
            let val = target.value.replace(/\D/g, ''); // Strip non-digits
            if (val.length >= 2) {
                target.value = val.slice(0, 2) + '/' + val.slice(2, 4);
            } else {
                target.value = val;
            }
        });

        // Tab Navigation Logic
        function switchTab(tabId) {
            // Hide all contents and remove active class from buttons
            document.querySelectorAll('.sis-tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.sis-tab-btn').forEach(b => b.classList.remove('active'));
            
            // Show targeted content and activate button
            document.getElementById('tab-' + tabId).classList.add('active');
            event.currentTarget.classList.add('active');
        }
    </script>
</body>
</html>
