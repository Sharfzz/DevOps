<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - Campus Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <%
        const isStaff = userProfile.campusId && userProfile.campusId.toUpperCase().startsWith('E');
        const role = isStaff ? 'Staff' : 'Student';
        const avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(userProfile.fullName)}&background=${isStaff ? '8b5cf6' : '3b82f6'}&color=fff&size=128`;
    %>

    <div class="dashboard-container">
        <div class="greeting-banner <%= isStaff ? 'staff-banner' : '' %>">
            <img src="<%= avatarUrl %>" alt="Profile Avatar" class="greeting-avatar">
            <div class="greeting-text">
                <h1>
                    Welcome back, <%= userProfile.fullName %>!
                    <span class="role-inline">(<%= role %>)</span>
                </h1>
                <p>Campus Portal</p>
            </div>
        </div>

        <div class="dashboard-grid">
            <div>
                <div class="dash-card">
                    <h2 class="dash-card-header">Your Profile</h2>

                    <div class="profile-info">
                        <div class="info-row">
                            <span class="info-label">Name</span>
                            <span class="info-value"><%= userProfile.fullName %></span>
                        </div>

                        <div class="info-row">
                            <span class="info-label"><%= isStaff ? 'Staff ID' : 'Student ID' %></span>
                            <span class="info-value"><%= userProfile.campusId %></span>
                        </div>

                        <div class="info-row">
                            <span class="info-label">Role</span>
                            <span class="role-badge <%= isStaff ? 'staff' : '' %>"><%= role %></span>
                        </div>

                        <div class="info-row" style="margin-top: 0.5rem;">
                            <span class="info-label">Recovery Key</span>
                            <div class="recovery-key-container profile-key-box">
                                <span id="profile-key-text" class="key-text">CP-**********</span>
                                <button
                                    type="button"
                                    id="profile-toggle-btn"
                                    data-real-key="<%= userProfile.recoveryKey || '' %>"
                                    onclick="handleProfileKeyToggle()"
                                    class="btn-view"
                                >
                                    Reveal Key
                                </button>
                            </div>
                        </div>
                    </div>

                    <form action="/profile/regenerate-key" method="POST" style="margin-top: 18px;">
                        <button type="submit" class="btn-regenerate">Regenerate Recovery Key</button>
                    </form>
                </div>
            </div>

            <div class="dash-card">
                <h2 class="dash-card-header">Account Details</h2>

                <div class="profile-info">
                    <div class="info-row">
                        <span class="info-label">Security Question</span>
                        <span class="info-value"><%= userProfile.securityQuestion || 'N/A' %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Course</span>
                        <span class="info-value"><%= userProfile.course || 'N/A' %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">School</span>
                        <span class="info-value"><%= userProfile.school || 'N/A' %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Personal Email</span>
                        <span class="info-value"><%= userProfile.personalEmail || 'N/A' %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Campus Email</span>
                        <span class="info-value"><%= userProfile.campusEmail || 'N/A' %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Contact Mobile</span>
                        <span class="info-value"><%= userProfile.contactMobile || 'N/A' %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Address</span>
                        <span class="info-value"><%= userProfile.address || 'N/A' %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function handleProfileKeyToggle() {
            const keyLabel = document.getElementById('profile-key-text');
            const actionBtn = document.getElementById('profile-toggle-btn');
            if (!keyLabel || !actionBtn) return;

            const rawValue = actionBtn.getAttribute('data-real-key') || '';
            const hiddenMask = 'CP-**********';

            if (keyLabel.innerText.trim() === hiddenMask) {
                keyLabel.innerText = rawValue || hiddenMask;
                actionBtn.innerText = 'Hide Key';
            } else {
                keyLabel.innerText = hiddenMask;
                actionBtn.innerText = 'Reveal Key';
            }
        }
    </script>
</body>
</html>