<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Campus Portal - Profile</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

    <style>
        body {
            background-color: #f8fafc;
            margin: 0;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .sis-container {
            width: 95%;
            max-width: 1500px;
            margin: 40px auto;
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 40px;
            align-items: start;
        }

        .sis-sidebar {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
            text-align: center;
            overflow: hidden;
            border: 1px solid #f1f5f9;
        }

        .sis-sidebar-cover {
            background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
            height: 120px;
            width: 100%;
            margin-bottom: -60px;
        }

        .sis-avatar {
            width: 110px;
            height: 110px;
            background: #1e293b;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            font-weight: bold;
            margin: 0 auto 16px;
            border: 6px solid white;
        }

        .sis-name {
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
        }

        .sis-badge {
            display: inline-block;
            background: #e0f2fe;
            color: #0284c7;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 24px;
        }

        .sis-contact-list {
            text-align: left;
            background: #f8fafc;
            padding: 24px;
            border-top: 1px solid #f1f5f9;
        }

        .sis-contact-item {
            display: flex;
            gap: 14px;
            margin-bottom: 16px;
            color: #475569;
            font-size: 14px;
        }

        .sis-main {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .sis-tab-btn {
            background: transparent;
            border: none;
            padding: 16px 24px;
            font-weight: 600;
            cursor: pointer;
            color: #64748b;
        }

        .sis-tab-btn.active {
            color: #0f172a;
            border-bottom: 2px solid #0f172a;
        }

        .sis-tab-content {
            display: none;
        }

        .sis-tab-content.active {
            display: block;
        }

        .sis-data-group {
            background: white;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            margin-bottom: 24px;
        }

        .sis-data-title {
            padding: 20px;
            font-weight: 700;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
        }

        .sis-row {
            display: flex;
            padding: 20px;
            border-bottom: 1px solid #f1f5f9;
        }

        .sis-label {
            width: 220px;
            color: #64748b;
            font-weight: 600;
            flex-shrink: 0;
        }

        .security-actions {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 14px;
        }

        .recovery-key-line {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        #profile-key-text {
            font-weight: 600;
            color: #0f172a;
        }

        #profile-toggle-btn {
            background: #e2e8f0;
            color: #0f172a;
            border: none;
            padding: 8px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

        #profile-toggle-btn:hover {
            background: #cbd5e1;
        }

        .btn-danger {
            background: #ef4444;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

        .btn-danger:hover {
            background: #dc2626;
        }

        @media (max-width: 900px) {
            .sis-container {
                grid-template-columns: 1fr;
            }

            .sis-row {
                flex-direction: column;
                gap: 10px;
            }

            .sis-label {
                width: 100%;
            }
        }
    </style>
</head>

<body>
<%- include('partials/navbar') %>

<%
    const isStaff = userProfile.campusId && userProfile.campusId.toUpperCase().startsWith('E');
    const role = isStaff ? 'Staff' : 'Student';
%>

<div class="sis-container">

    <!-- SIDEBAR -->
    <aside class="sis-sidebar">
        <div class="sis-sidebar-cover"></div>

        <div class="sis-avatar">
            <%= userProfile.fullName.charAt(0).toUpperCase() %>
        </div>

        <h1 class="sis-name"><%= userProfile.fullName %></h1>
        <div class="sis-badge"><%= role %></div>

        <div class="sis-contact-list">
            <div class="sis-contact-item">
                <%= userProfile.campusEmail || 'Pending Setup' %>
            </div>
            <div class="sis-contact-item">
                <%= userProfile.contactMobile || 'N/A' %>
            </div>
            <div class="sis-contact-item">
                ID: <%= userProfile.campusId %>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <main class="sis-main">

        <div>
            <button class="sis-tab-btn active" onclick="switchTab(event,'academic')">Academic</button>
            <button class="sis-tab-btn" onclick="switchTab(event,'contact')">Contact</button>
            <button class="sis-tab-btn" onclick="switchTab(event,'security')">Security</button>
        </div>

        <div id="tab-academic" class="sis-tab-content active">
            <div class="sis-data-group">
                <div class="sis-data-title">Academic Info</div>
                <div class="sis-row">
                    <div class="sis-label">Name</div>
                    <div><%= userProfile.fullName %></div>
                </div>
                <div class="sis-row">
                    <div class="sis-label">Course</div>
                    <div><%= userProfile.course || 'N/A' %></div>
                </div>
            </div>
        </div>

        <div id="tab-contact" class="sis-tab-content">
            <div class="sis-data-group">
                <div class="sis-data-title">Contact</div>
                <div class="sis-row">
                    <div class="sis-label">Email</div>
                    <div><%= userProfile.personalEmail || 'N/A' %></div>
                </div>
            </div>
        </div>

        <div id="tab-security" class="sis-tab-content">
            <div class="sis-data-group">
                <div class="sis-data-title">Security</div>

                <div class="sis-row">
                    <div class="sis-label">Recovery Key</div>
                    <div class="security-actions">
                        <div class="recovery-key-line">
                            <span id="profile-key-text">CP-**********</span>
                            <button
                                type="button"
                                onclick="handleProfileKeyToggle()"
                                id="profile-toggle-btn"
                                data-real-key="<%= userProfile.recoveryKey %>">
                                Reveal
                            </button>
                        </div>

                        <form action="/profile/regenerate-key" method="POST">
                            <button class="btn-danger" type="submit">Regenerate Key</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </main>
</div>

<script>
function switchTab(event, tabId) {
    document.querySelectorAll('.sis-tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.sis-tab-btn').forEach(b => b.classList.remove('active'));

    document.getElementById('tab-' + tabId).classList.add('active');
    event.currentTarget.classList.add('active');
}

function handleProfileKeyToggle() {
    const keyLabel = document.getElementById('profile-key-text');
    const btn = document.getElementById('profile-toggle-btn');

    const real = btn.getAttribute('data-real-key');
    const mask = 'CP-**********';

    if (keyLabel.innerText === mask) {
        keyLabel.innerText = real || mask;
        btn.innerText = 'Hide';
    } else {
        keyLabel.innerText = mask;
        btn.innerText = 'Reveal';
    }
}
</script>

</body>
</html>