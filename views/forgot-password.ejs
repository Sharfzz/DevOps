<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Campus Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Reset Password</h1>
                <p>Enter your Student/Staff ID and choose a recovery method</p>
            </div>

            <form action="/forgot-password" method="POST">
                <div class="form-group">
                    <label for="campusId" class="form-label">Student/Staff ID</label>
                    <input
                        type="text"
                        id="campusId"
                        name="campusId"
                        class="form-input"
                        placeholder="Enter your ID"
                        required
                    >
                </div>

                <div class="form-group">
                    <label class="form-label">Recovery Method</label>
                    <div style="display:flex; gap:10px; margin-bottom:10px; flex-wrap:wrap;">
                        <label style="display:flex; align-items:center; gap:6px;">
                            <input type="radio" name="recoveryMethod" value="key" checked onchange="toggleMethod()">
                            Recovery Key
                        </label>
                        <label style="display:flex; align-items:center; gap:6px;">
                            <input type="radio" name="recoveryMethod" value="question" onchange="toggleMethod()">
                            Security Answer
                        </label>
                    </div>
                </div>

                <div class="form-group" id="sectionKey">
                    <label for="recoveryKey" class="form-label">Recovery Key</label>
                    <input
                        type="text"
                        id="recoveryKey"
                        name="recoveryKey"
                        class="form-input"
                        placeholder="e.g. CP-1A2B3C4D"
                        required
                    >
                </div>

                <div class="form-group" id="sectionAnswer" style="display:none;">
                    <label for="securityAnswer" class="form-label">Security Answer</label>
                    <input
                        type="text"
                        id="securityAnswer"
                        name="securityAnswer"
                        class="form-input"
                        placeholder="Your Answer"
                    >
                </div>

                <button type="submit" class="btn-submit">Verify Identity</button>

                <div class="auth-footer">
                    Remembered your password? <a href="/login" class="text-link">Sign in</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleMethod() {
            const method = document.querySelector('input[name="recoveryMethod"]:checked').value;
            const sectionKey = document.getElementById('sectionKey');
            const sectionAnswer = document.getElementById('sectionAnswer');
            const inputKey = document.getElementById('recoveryKey');
            const inputAnswer = document.getElementById('securityAnswer');

            if (method === 'key') {
                sectionKey.style.display = 'block';
                sectionAnswer.style.display = 'none';
                inputKey.required = true;
                inputAnswer.required = false;
            } else {
                sectionKey.style.display = 'none';
                sectionAnswer.style.display = 'block';
                inputKey.required = false;
                inputAnswer.required = true;
            }
        }
    </script>
</body>
</html>