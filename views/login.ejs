<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Campus Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <style>
            /* New Split Layout Styles */
            .split-layout {
                display: flex;
                min-height: 85vh;
            }
            .brand-panel {
                flex: 1;
                background: linear-gradient(135deg, #1e293b, #312e81);
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                color: white;
                padding: 2rem;
                text-align: center;
            }
            .brand-panel h1 {
                font-size: 2.5rem;
                margin-bottom: 1rem;
                font-weight: 600;
            }
            .brand-panel p {
                font-size: 1.1rem;
                opacity: 0.9;
                max-width: 80%;
                line-height: 1.5;
            }
            .form-panel {
                flex: 1;
                background-color: #f8fafc;
                display: flex;
                justify-content: center;
                align-items: center;
            }
            /* Override default auth-container */
            .form-panel .auth-container {
                min-height: auto;
                background: transparent;
                padding: 2rem;
                width: 100%;
                display: flex;
                justify-content: center;
            }
            /* Card Refinements */
            .form-panel .auth-card {
                background-color: #ffffff;
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
                border: none;
                width: 100%;
                max-width: 450px;
                border-radius: 12px;
            }
            /* Input & Button Refinements */
            .form-panel .form-input, .form-panel .form-select {
                border: 1px solid #cbd5e1;
                transition: all 0.2s ease;
            }
            .form-panel .form-input:focus, .form-panel .form-select:focus {
                outline: none;
                border-color: #1e293b;
                box-shadow: 0 0 0 3px rgba(30, 41, 59, 0.1);
            }
            .form-panel .btn-submit {
                background-color: #1e293b;
                color: white;
                transition: background-color 0.2s ease;
            }
            .form-panel .btn-submit:hover {
                background-color: #334155;
            }
            @media (max-width: 768px) {
                .split-layout {
                    flex-direction: column;
                }
                .brand-panel {
                    min-height: 250px;
                }
            }
        </style>
        <div class="split-layout">
            <div class="brand-panel">
                <h1>Campus Identity & Access Management</h1>
                <p>Secure, centralized access to all your campus resources and applications.</p>
            </div>
            <div class="form-panel">
                <div class="auth-container">
                    <div class="auth-card">
                <div class="auth-header">
                    <h1>Welcome Back</h1>
                    <p>Please enter your details to sign in</p>
                </div>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label for="campusId" class="form-label">Student/Staff ID</label>
                        <input type="text" id="campusId" name="campusId" class="form-input" placeholder="Enter your ID"
                            required>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" id="password" name="password" class="form-input"
                            placeholder="Enter your password" required>
                        <button type="button" class="password-toggle" onclick="togglePassword('password', 'eye-icon')">
                            <svg id="eye-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </div>

                    <div class="form-options">
                        <div class="checkbox-group">
                            <input type="checkbox" id="remember" name="remember">
                            <label for="remember">Remember me</label>
                        </div>
                        <a href="/forgot-password" class="text-link">Forgot Password?</a>
                    </div>

                    <button type="submit" class="btn-submit">Sign In</button>

                    <div class="auth-footer">
                        Don't have an account? <a href="/register" class="text-link">Register here</a>
                    </div>
                </form>
            </div>
        </div>
            </div>
        </div>

        <script>
            function togglePassword(inputId, iconId) {
                const input = document.getElementById(inputId);
                const icon = document.getElementById(iconId);

                if (input.type === 'password') {
                    input.type = 'text';
                    icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
                } else {
                    input.type = 'password';
                    icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
                }
            }
        </script>
</body>

</html>