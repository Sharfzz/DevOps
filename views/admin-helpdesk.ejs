<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Helpdesk - Campus Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="dashboard-container">
        <div class="greeting-banner staff-banner">
            <div class="greeting-text">
                <h1>Admin Helpdesk</h1>
                <p>Manage user recovery and reset access when needed.</p>
            </div>
        </div>

        <div class="dash-card">
            <h2 class="dash-card-header">Registered Users</h2>
            
            <% if (typeof generatedPin !== 'undefined' && generatedPin) { %>
                <div style="background-color: #dcfce7; color: #14532d; border: 1px solid #bbf7d0; padding: 15px; border-radius: 8px; margin-bottom: 20px; font-weight: 500;">
                    Success! Temporary PIN for <%= generatedPinUser %> is: <strong style="font-size: 1.1em; letter-spacing: 1px;"><%= generatedPin %></strong>. Instruct the student to log in with this PIN immediately.
                </div>
            <% } %>

            <input type="text" id="searchInput" placeholder="Search by Name or ID..." style="width: 100%; max-width: 400px; padding: 10px; margin-bottom: 20px; border: 1px solid #e2e8f0; border-radius: 6px;">

            <% if (!users || users.length === 0) { %>
                <p class="no-data">No users found.</p>
            <% } else { %>
                <div class="table-wrap">
                    <table class="admin-table" id="usersTable">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Campus ID</th>
                                <th>Role</th>
                                <th>Registered</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(user => { %>
                                <tr class="<%= user.manualResetRequested ? 'highlight-row' : '' %>">
                                    <td class="user-name">
                                        <%= user.fullName %>
                                        <% if (user.manualResetRequested === true) { %>
                                            <span style="background-color: #feebc8; color: #c05621; font-size: 0.75em; padding: 2px 6px; border-radius: 12px; margin-left: 8px; font-weight: 600;">Reset Requested</span>
                                        <% } %>
                                    </td>
                                    <td class="user-id"><%= user.campusId %></td>
                                    <td>
                                        <span class="role-badge <%= user.role === 'Admin' ? 'staff' : '' %>">
                                            <%= user.role %>
                                        </span>
                                    </td>
                                    <td>
                                        <%= user.isRegistered ? 'Yes' : 'No' %>
                                    </td>
                                    <td>
                                        <div style="display: flex; flex-direction: row; align-items: center; justify-content: flex-start; gap: 10px; height: 100%;">
                                            <% if (user.manualResetRequested === true) { %>
                                                <form action="/admin/approve-reset" method="POST" style="margin: 0 !important; padding: 0 !important; display: flex; align-items: center; height: fit-content;">
                                                    <input type="hidden" name="targetUserId" value="<%= user._id %>">
                                                    <button type="submit" class="btn-approve-reset" style="background-color: #ef4444; color: white; margin: 0 !important; padding: 0 16px; border-radius: 6px; border: none; font-size: 14px; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; box-sizing: border-box; height: 36px;">Approve Reset</button>
                                                </form>
                                            <% } %>
                                            <form action="/admin/reset-user" method="POST" style="margin: 0 !important; padding: 0 !important; display: flex; align-items: center; height: fit-content;">
                                                <input type="hidden" name="targetUserId" value="<%= user._id %>">
                                                <button type="submit" class="btn-regenerate" style="background-color: #0f172a; color: white; margin: 0 !important; padding: 0 16px; border-radius: 6px; border: none; font-size: 14px; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; box-sizing: border-box; height: 36px;">
                                                    Admin Reset
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>

    <style>
        .table-wrap {
            overflow-x: auto;
        }

        .btn-approve-reset {
            background-color: #ef4444;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            line-height: 1.5;
            text-align: center;
            transition: background-color 0.2s ease;
        }
        .btn-approve-reset:hover {
            background-color: #dc2626;
        }

        .btn-regenerate {
            background-color: #0f172a;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            line-height: 1.5;
            text-align: center;
            transition: background-color 0.2s ease;
        }
        .btn-regenerate:hover {
            background-color: #1e293b;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
            min-width: 900px;
        }

        .admin-table th,
        .admin-table td {
            padding: 14px 12px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            vertical-align: middle;
        }

        .admin-table th {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #64748b;
            font-weight: 700;
        }

        .admin-table td {
            color: #0f172a;
        }

        .mono-cell {
            font-family: monospace;
        }

        .no-data {
            color: #64748b;
            padding: 16px 0;
        }

        .highlight-row {
            background-color: #fffaf0;
            border-left: 4px solid #dd6b20;
        }
    </style>

    <script>
        document.getElementById('searchInput')?.addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            const rows = document.querySelectorAll('#usersTable tbody tr');

            rows.forEach(row => {
                const name = row.querySelector('.user-name')?.textContent.toLowerCase() || '';
                const id = row.querySelector('.user-id')?.textContent.toLowerCase() || '';

                if (name.includes(filter) || id.includes(filter)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>
