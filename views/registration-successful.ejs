<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registration Successful</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #eef2ff, #f8fafc);
      color: #0f172a;
      padding: 24px;
    }
    .card {
      width: 100%;
      max-width: 520px;
      background: #fff;
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
      text-align: center;
      border: 1px solid #e2e8f0;
    }
    .icon {
      width: 84px;
      height: 84px;
      border-radius: 50%;
      background: #dcfce7;
      color: #16a34a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      margin: 0 auto 20px;
    }
    h1 { font-size: 2rem; margin-bottom: 12px; }
    p { color: #475569; line-height: 1.6; margin-bottom: 14px; }
    .recovery {
      margin: 22px 0;
      padding: 16px;
      border-radius: 12px;
      background: #f8fafc;
      border: 1px dashed #cbd5e1;
      font-family: monospace;
      font-size: 1.05rem;
      color: #0f172a;
      word-break: break-word;
    }
    .btn {
      display: inline-block;
      margin-top: 10px;
      padding: 12px 20px;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 600;
      background: #2563eb;
      color: white;
    }
    .btn:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">✓</div>
    <h1>Registration Successful</h1>
    <p>Your account has been created successfully.</p>

    <% if (typeof recoveryKey !== 'undefined' && recoveryKey) { %>
      <p>Save this recovery key somewhere safe:</p>
      <div class="recovery"><%= recoveryKey %></div>
    <% } %>

    <p>You can now sign in with your campus ID and password.</p>
    <a href="/login" class="btn">Go to Login</a>
  </div>
</body>
</html>