<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Campus Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <div class="auth-container">
            <div class="auth-card">
                <div class="auth-header">
                    <h1>Create Account</h1>
                    <p>Register for access to the Campus Portal</p>
                </div>

                <form action="/register" method="POST">
                    <div class="form-group">
                        <label for="fullName" class="form-label">Full Name</label>
                        <input type="text" id="fullName" name="fullName" class="form-input"
                            placeholder="Enter your full name" required>
                        <div id="fullNameError" class="error-msg" style="color: red; font-size: 0.8rem; margin-top: 5px;"></div>
                    </div>

                    <div class="form-group">
                        <label for="campusId" class="form-label">Student/Staff ID</label>
                        <input type="text" id="campusId" name="campusId" class="form-input" placeholder="Enter your ID"
                            required>
                        <div id="campusIdError" class="error-msg" style="color: red; font-size: 0.8rem; margin-top: 5px;"></div>
                    </div>

                    <div class="form-group">
                        <label for="securityQuestion" class="form-label">Security Question</label>
                        <select id="securityQuestion" name="securityQuestion" class="form-select" required>
                            <option value="" disabled selected>Select a security question</option>
                            <option value="First pet's name">First pet's name</option>
                            <option value="Primary school attended">Primary school attended</option>
                            <option value="Mother's maiden name">Mother's maiden name</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="securityAnswer" class="form-label">Security Answer</label>
                        <input type="text" id="securityAnswer" name="securityAnswer" class="form-input" placeholder="Your Answer" required>
                    </div>

                    <div class="form-group">
                        <label for="role" class="form-label">Role</label>
                        <select id="role" name="role" class="form-select" required>
                            <option value="" disabled selected>Select your role</option>
                            <option value="Student">Student</option>
                            <option value="Admin">School Staff (Admin)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" id="password" name="password" class="form-input"
                            placeholder="Create a password" required>
                        <button type="button" class="password-toggle"
                            onclick="togglePassword('password', 'eye-icon-1')">
                            <svg id="eye-icon-1" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword" class="form-label">Confirm Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-input"
                            placeholder="Confirm your password" required>
                        <button type="button" class="password-toggle"
                            onclick="togglePassword('confirmPassword', 'eye-icon-2')">
                            <svg id="eye-icon-2" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                        <div id="passwordError" class="error-msg" style="color: red; font-size: 0.8rem; margin-top: 5px;"></div>
                    </div>

                    <div class="form-options">
                        <div class="checkbox-group">
                            <input type="checkbox" id="terms" name="terms" required>
                            <label for="terms">I agree to the <a href="#" class="text-link">campus terms of
                                    use</a></label>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="btn-submit" disabled>Create Account</button>

                    <div class="auth-footer">
                        Already have an account? <a href="/login" class="text-link">Sign in</a>
                    </div>
                </form>
            </div>
        </div>

        <script>
            function togglePassword(inputId, iconId) {
                const input = document.getElementById(inputId);
                const icon = document.getElementById(iconId);

                if (input.type === 'password') {
                    input.type = 'text';
                    icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
                } else {
                    input.type = 'password';
                    icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const fullNameInput = document.getElementById('fullName');
                const campusIdInput = document.getElementById('campusId');
                const roleSelect = document.getElementById('role');
                const passwordInput = document.getElementById('password');
                const confirmPasswordInput = document.getElementById('confirmPassword');
                const termsCheckbox = document.getElementById('terms');
                const submitBtn = document.getElementById('submitBtn');

                const fullNameError = document.getElementById('fullNameError');
                const campusIdError = document.getElementById('campusIdError');
                const passwordError = document.getElementById('passwordError');

                let debounceTimer;

                const state = {
                    fullName: false,
                    campusId: false,
                    passwords: false,
                    terms: false
                };

                function validateForm() {
                    submitBtn.disabled = !(state.fullName && state.campusId && state.passwords && state.terms);
                }

                async function checkAvailability(field, value, errorElement) {
                    if (!value) {
                        errorElement.textContent = 'This field is required';
                        state[field] = false;
                        validateForm();
                        return;
                    }
                    try {
                        const res = await fetch(`/api/check-user?field=${field}&value=${encodeURIComponent(value)}`);
                        const data = await res.json();
                        
                        if (data.exists) {
                            errorElement.textContent = field === 'fullName' ? 'Name is taken' : 'This ID is already registered';
                            state[field] = false;
                        } else {
                            errorElement.textContent = '';
                            state[field] = true;
                        }
                    } catch (e) {
                        console.error(e);
                    }
                    validateForm();
                }

                function validateCampusId() {
                    const val = campusIdInput.value;
                    const role = roleSelect.value;
                    
                    if (!val) {
                        campusIdError.textContent = 'This field is required';
                        state.campusId = false;
                        validateForm();
                        return false;
                    }
                    
                    if (role) {
                        const prefix = val.charAt(0).toUpperCase();
                        if (role === 'Student' && prefix !== 'S') {
                            campusIdError.textContent = 'Student ID must start with S';
                            state.campusId = false;
                            validateForm();
                            return false;
                        }
                        if (role === 'Admin' && prefix !== 'E') {
                            campusIdError.textContent = 'Admin ID must start with E';
                            state.campusId = false;
                            validateForm();
                            return false;
                        }
                    }
                    
                    return true;
                }

                function handleCampusIdChange() {
                    if (validateCampusId()) {
                        checkAvailability('campusId', campusIdInput.value, campusIdError);
                    }
                }

                function handleFullNameChange() {
                    checkAvailability('fullName', fullNameInput.value, fullNameError);
                }

                function handlePasswordChange() {
                    const p1 = passwordInput.value;
                    const p2 = confirmPasswordInput.value;
                    if (!p1 || !p2) {
                        state.passwords = false;
                        passwordError.textContent = '';
                    } else if (p1 !== p2) {
                        state.passwords = false;
                        passwordError.textContent = 'Passwords do not match';
                    } else {
                        state.passwords = true;
                        passwordError.textContent = '';
                    }
                    validateForm();
                }

                function debounce(func, delay = 500) {
                    return (...args) => {
                        clearTimeout(debounceTimer);
                        debounceTimer = setTimeout(() => func(...args), delay);
                    };
                }

                fullNameInput.addEventListener('input', debounce(handleFullNameChange));
                fullNameInput.addEventListener('blur', handleFullNameChange);

                campusIdInput.addEventListener('input', debounce(handleCampusIdChange));
                campusIdInput.addEventListener('blur', handleCampusIdChange);
                roleSelect.addEventListener('change', handleCampusIdChange);

                passwordInput.addEventListener('input', handlePasswordChange);
                confirmPasswordInput.addEventListener('input', handlePasswordChange);
                
                termsCheckbox.addEventListener('change', (e) => {
                    state.terms = e.target.checked;
                    validateForm();
                });
            });
        </script>
</body>

</html>