<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Help Forum</title>

    <script>
        (() => {
            const savedTheme = localStorage.getItem("theme");
            if (savedTheme === "dark") {
                document.documentElement.classList.add("dark");
            }
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/forum.css">
</head>
<body>

    <%- include('partials/navbar') %>

    <div class="container">

        <% if (success) { %>
            <div class="notification success-notification" id="successNotification">
                <% if (success === "question-posted") { %>
                    ✅ Question posted successfully!
                <% } else if (success === "reply-posted") { %>
                    ✅ Reply submitted!
                <% } else if (success === "question-deleted") { %>
                    ✅ Question deleted successfully!
                <% } else if (success === "question-updated") { %>
                    ✅ Question updated successfully!
                <% } %>
            </div>
        <% } %>

        <section class="hero">
            <div class="hero-top">
                <div>
                    <h1>📚 Student Help Forum</h1>
                    <p>Ask questions, share knowledge and help your classmates succeed.</p>
                </div>

                <button id="themeToggle" class="theme-toggle" type="button">
                    🌙 Dark Mode
                </button>
            </div>
        </section>

        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">❓</div>
                <div>
                    <p class="stat-label">Total Questions</p>
                    <h3><%= totalQuestions %></h3>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">💬</div>
                <div>
                    <p class="stat-label">Total Replies</p>
                    <h3><%= totalReplies %></h3>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">📘</div>
                <div>
                    <p class="stat-label">Total Modules</p>
                    <h3><%= totalModules %></h3>
                </div>
            </div>
        </section>

        <section class="ask-card">
            <h2>Ask a Question</h2>

            <form action="/forum" method="POST">
                <label for="module">Module</label>
                <select name="module" id="module" required>
                    <option value="">Select a module</option>
                    <option value="C229 OS & Cloud Computing">C229 OS & Cloud Computing</option>
                    <option value="C237 Software App Dev">C237 Software App Dev</option>
                    <option value="C270 DevOps Essentials">C270 DevOps Essentials</option>
                    <option value="C328 Intelligent Networks">C328 Intelligent Networks</option>
                    <option value="C330 Linux Administration">C330 Linux Administration</option>
                    <option value="Other">Other</option>
                </select>

                <label for="title">Question Title</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    placeholder="Enter your question"
                    required
                >

                <label for="description">Description</label>
                <textarea
                    rows="5"
                    id="description"
                    name="description"
                    placeholder="Describe your problem..."
                    required
                ></textarea>

                <button type="submit" class="primary-btn">Post Question</button>
            </form>
        </section>

        <section class="search-card">
            <h2>Search Questions</h2>
            <input
                type="text"
                id="searchInput"
                placeholder="Search by module, title or description..."
            >
        </section>

        <section class="forum">
            <div class="forum-header">
                <h2>Recent Questions</h2>
                <p id="resultCount"><%= questions.length %> question(s)</p>
            </div>

            <% if (questions.length === 0) { %>
                <div class="empty">
                    No questions yet.
                </div>
            <% } %>

            <div id="questionsWrapper">
                <% questions.forEach((question) => { %>
                    <article
                        class="question-card searchable-question"
                        data-module="<%= question.module.toLowerCase() %>"
                        data-title="<%= question.title.toLowerCase() %>"
                        data-description="<%= question.description.toLowerCase() %>"
                    >
                        <div class="question-top">
                            <div class="question-meta-row">
                                <span class="module"><%= question.module %></span>

                                <% if (question.solved) { %>
                                    <span class="solved-badge solved">🟢 Solved</span>
                                <% } else { %>
                                    <span class="solved-badge unsolved">🔴 Unsolved</span>
                                <% } %>
                            </div>

                            <div class="question-actions">
                                <% if (!question.solved) { %>
                                    <form action="/forum/solved/<%= question.id %>" method="POST">
                                        <button type="submit" class="action-btn solved-btn">
                                            Mark as Solved
                                        </button>
                                    </form>
                                <% } else { %>
                                    <button type="button" class="action-btn disabled-btn" disabled>
                                        Solved
                                    </button>
                                <% } %>

                                <a href="/forum/edit/<%= question.id %>" class="action-btn edit-btn">
                                    Edit
                                </a>

                                <form
                                    action="/forum/delete/<%= question.id %>"
                                    method="POST"
                                    onsubmit="return confirm('Are you sure you want to delete this question?')"
                                >
                                    <button type="submit" class="action-btn delete-btn">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>

                        <h3><%= question.title %></h3>

                        <p class="question-description"><%= question.description %></p>

                        <div class="question-footer">
                            <small>
                                Posted by <strong><%= question.student %></strong>
                            </small>
                            <small class="time-text">
                                <%= question.relativeTime %>
                            </small>
                        </div>

                        <hr>

                        <div class="reply-section">
                            <h4>💬 Replies (<%= question.replies.length %>)</h4>

                            <% if (question.replies.length === 0) { %>
                                <p class="noReply">No replies yet.</p>
                            <% } %>

                            <% question.replies.forEach((reply, replyIndex) => { %>
                                <div class="reply">
                                    <div class="reply-top">
                                        <strong><%= reply.student %></strong>
                                        <small class="time-text"><%= reply.relativeTime %></small>
                                    </div>

                                    <p><%= reply.text %></p>

                                    <form action="/forum/reply/helpful/<%= question.id %>/<%= replyIndex %>" method="POST">
                                        <button type="submit" class="helpful-btn">
                                            👍 Helpful (<%= reply.helpful %>)
                                        </button>
                                    </form>
                                </div>
                            <% }) %>

                            <form action="/forum/reply/<%= question.id %>" method="POST" class="replyForm">
                                <textarea
                                    name="reply"
                                    rows="3"
                                    placeholder="Write your reply..."
                                    required
                                ></textarea>

                                <button type="submit" class="primary-btn">Reply</button>
                            </form>
                        </div>
                    </article>
                <% }) %>
            </div>

            <div class="empty search-empty" id="noSearchResults" style="display: none;">
                No matching questions found.
            </div>
        </section>
    </div>

    <script>
        const searchInput = document.getElementById("searchInput");
        const questionCards = document.querySelectorAll(".searchable-question");
        const resultCount = document.getElementById("resultCount");
        const noSearchResults = document.getElementById("noSearchResults");

        searchInput.addEventListener("input", () => {
            const searchValue = searchInput.value.toLowerCase().trim();
            let visibleCount = 0;

            questionCards.forEach(card => {
                const module = card.dataset.module;
                const title = card.dataset.title;
                const description = card.dataset.description;

                const matches =
                    module.includes(searchValue) ||
                    title.includes(searchValue) ||
                    description.includes(searchValue);

                if (matches) {
                    card.style.display = "block";
                    visibleCount++;
                } else {
                    card.style.display = "none";
                }
            });

            resultCount.textContent = `${visibleCount} question(s)`;
            noSearchResults.style.display = visibleCount === 0 ? "block" : "none";
        });

        const notification = document.getElementById("successNotification");
        if (notification) {
            setTimeout(() => {
                notification.style.opacity = "0";
                notification.style.transform = "translateY(-10px)";
                setTimeout(() => {
                    notification.style.display = "none";
                }, 300);
            }, 3000);
        }

        const themeToggle = document.getElementById("themeToggle");

        function updateThemeButton() {
            if (document.documentElement.classList.contains("dark")) {
                themeToggle.textContent = "☀ Light Mode";
            } else {
                themeToggle.textContent = "🌙 Dark Mode";
            }
        }

        updateThemeButton();

        themeToggle.addEventListener("click", () => {
            document.documentElement.classList.toggle("dark");

            if (document.documentElement.classList.contains("dark")) {
                localStorage.setItem("theme", "dark");
            } else {
                localStorage.setItem("theme", "light");
            }

            updateThemeButton();
        });
    </script>
</body>
</html>