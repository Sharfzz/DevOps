<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campus Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <% 
    const isStaff = profile.campusId && profile.campusId.toUpperCase().startsWith('E');
    const role = isStaff ? 'Staff' : 'Student';
    const avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(profile.fullName)}&background=${isStaff ? '8b5cf6' : '3b82f6'}&color=fff&size=128`;
  %>

  <div class="dashboard-container">
    <div class="greeting-banner <%= isStaff ? 'staff-banner' : '' %>">
      <img src="<%= avatarUrl %>" alt="Profile Avatar" class="greeting-avatar">
      <div class="greeting-text">
        <h1>Welcome back, <%= profile.fullName %>! <span class="role-inline">(<%= role %>)</span></h1>
        <p>Campus Portal</p>
      </div>
    </div>

    <div class="dashboard-grid">
      <div>
        <div class="dash-card">
          <h2 class="dash-card-header">Your Profile</h2>
          <div class="profile-info">
            <div class="info-row">
              <span class="info-label">Name</span>
              <span class="info-value"><%= profile.fullName %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><%= isStaff ? 'Staff ID' : 'Student ID' %></span>
              <span class="info-value"><%= profile.campusId %></span>
            </div>
            <div class="info-row">
              <span class="info-label">Role</span>
              <span class="role-badge <%= isStaff ? 'staff' : '' %>"><%= role %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="dashboard-right">
        <div class="dash-card">
          <h2 class="dash-card-header">Quick Access</h2>
          <div class="quick-access-grid">
            <% if (profile.role === 'Admin') { %>
              <a href="/admin/helpdesk" class="qa-item staff">
                <div class="qa-icon">⚙️</div>
                <span class="qa-text">Helpdesk</span>
              </a>
              <a href="/forum" class="qa-item staff">
                <div class="qa-icon">💬</div>
                <span class="qa-text">Forum</span>
              </a>
              <a href="/profile" class="qa-item staff">
                <div class="qa-icon">👤</div>
                <span class="qa-text">Profile</span>
              </a>
            <% } else { %>
              <a href="/forum" class="qa-item">
                <div class="qa-icon">💬</div>
                <span class="qa-text">Student Forum</span>
              </a>
              <a href="/profile" class="qa-item">
                <div class="qa-icon">👤</div>
                <span class="qa-text">Profile</span>
              </a>
              <a href="/admin/helpdesk" class="qa-item">
                <div class="qa-icon">🛠️</div>
                <span class="qa-text">Helpdesk</span>
              </a>
            <% } %>
          </div>
        </div>

        <div class="dash-card">
          <h2 class="dash-card-header">Notifications</h2>
          <ul class="notif-list">
            <li class="notif-item">
              <div class="notif-icon-wrap">💬</div>
              <div class="notif-content">
                <h4>Forum Reply</h4>
                <p>A classmate replied to a discussion thread.</p>
                <div class="notif-time">2 hours ago</div>
              </div>
            </li>
            <li class="notif-item success">
              <div class="notif-icon-wrap">✅</div>
              <div class="notif-content">
                <h4>Booking Confirmed</h4>
                <p>Study room booking has been approved.</p>
                <div class="notif-time">Yesterday</div>
              </div>
            </li>
            <li class="notif-item warning">
              <div class="notif-icon-wrap">⚠️</div>
              <div class="notif-content">
                <h4>System Update</h4>
                <p>Portal maintenance scheduled soon.</p>
                <div class="notif-time">3 days ago</div>
              </div>
            </li>
          </ul>
        </div>

        <div class="dash-card">
          <h2 class="dash-card-header">Portal Modules</h2>
          <div class="module-stack">
            <div class="module-item">
              <div>
                <h4>Academic Records</h4>
                <p>View transcripts and grades</p>
              </div>
              <button class="btn-module" type="button">Open</button>
            </div>
            <div class="module-item">
              <div>
                <h4>Financial Hub</h4>
                <p>Tuition and fee payments</p>
              </div>
              <a href="/financial" class="btn-module" style="text-decoration:none; display:inline-block;">Open</a>
            </div>
            <div class="module-item">
              <div>
                <h4>Course Registration</h4>
                <p>Enroll for next semester</p>
              </div>
              <button class="btn-module" type="button">Open</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>