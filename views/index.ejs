<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy"
        content="default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:;">
    <title>Campus Portal</title>
    <!-- Use Inter font for a modern, clean look -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Clean White Background */
            --bg-primary: #FFFFFF;

            /* Text Colors */
            --text-main: #111827;
            --text-muted: #6B7280;

            /* Navbar Variables */
            --nav-bg: rgba(255, 255, 255, 0.9);
            --nav-border: #E5E7EB;

            /* Interaction Colors */
            --accent: #3B82F6;
            --accent-hover: #2563EB;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-main);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* --- Navigation Bar --- */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 72px;
            padding: 0 5%;
            background-color: var(--nav-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--nav-border);
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-main);
            text-decoration: none;
            letter-spacing: -0.025em;
        }

        .navbar-menu {
            display: flex;
            align-items: center;
            gap: 2.5rem;
        }

        .nav-link {
            text-decoration: none;
            color: var(--text-muted);
            font-size: 0.95rem;
            font-weight: 500;
            transition: color 0.2s ease;
        }

        .nav-link:hover {
            color: var(--text-main);
        }

        .nav-link-login {
            background-color: var(--text-main);
            color: #FFFFFF;
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            transition: background-color 0.2s ease, transform 0.1s ease;
        }

        .nav-link-login:hover {
            background-color: var(--text-muted);
            color: #FFFFFF;
        }

        .nav-link-login:active {
            transform: scale(0.98);
        }

        /* Mobile Menu Toggle Button */
        .mobile-toggle {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.5rem;
        }

        .mobile-toggle svg {
            width: 24px;
            height: 24px;
            stroke: var(--text-main);
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        /* --- Main Content Layout --- */
        .main-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 5rem 5%;
        }

        .hero {
            text-align: center;
            margin-top: 2rem;
            animation: fadeIn 0.6s ease-out forwards;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 600;
            letter-spacing: -0.04em;
            margin-bottom: 1rem;
            color: var(--text-main);
        }

        .hero p {
            color: var(--text-muted);
            font-size: 1.125rem;
            max-width: 600px;
            margin: 0 auto;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* --- Responsive Styles --- */
        @media (max-width: 768px) {
            .navbar-menu {
                display: none;
                position: absolute;
                top: 72px;
                left: 0;
                right: 0;
                background-color: var(--bg-primary);
                flex-direction: column;
                align-items: center;
                padding: 1.5rem 0;
                gap: 1.5rem;
                border-bottom: 1px solid var(--nav-border);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            }

            /* Class added via JS for mobile menu toggle */
            .navbar-menu.is-open {
                display: flex;
            }

            .mobile-toggle {
                display: block;
            }

            .hero h1 {
                font-size: 2.5rem;
            }
        }
    </style>
</head>

<body>

    <!-- Navigation Bar -->
    <nav class="navbar">
        <a href="#" class="navbar-brand">Campus Portal</a>

        <!-- Mobile Toggle Icon -->
        <button class="mobile-toggle" aria-label="Toggle Menu"
            onclick="document.getElementById('navMenu').classList.toggle('is-open')">
            <svg viewBox="0 0 24 24" fill="none">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>

        <!-- Navigation Links -->
        <div id="navMenu" class="navbar-menu">
            <a href="#" class="nav-link">Home</a>
            <a href="#" class="nav-link">Student Forum</a>
            <a href="#" class="nav-link">Room Booking</a>
            <a href="#" class="nav-link-login">Login</a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-container">
        <section class="hero">
            <h1>Welcome to Campus Portal</h1>
            <p>Access your student resources, connect with peers, and manage your campus life efficiently.</p>
        </section>
    </main>

</body>

</html>