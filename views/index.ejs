<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campus Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <% const isStaff = profile.campusId && profile.campusId.toUpperCase().startsWith('E'); %>
  <% const role = profile.role || (isStaff ? 'Staff' : 'Student'); %>
  <% const avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(profile.fullName)}&background=${isStaff ? '8b5cf6' : '3b82f6'}&color=fff&size=128`; %>

  <div class="dashboard-container">
    <div class="greeting-banner <%= isStaff ? 'staff-banner' : '' %>">
      <img src="<%= avatarUrl %>" alt="Profile Avatar" class="greeting-avatar">
      <div class="greeting-text">
        <h1>Welcome back, <%= profile.fullName %>! <span class="role-inline">(<%= role %>)</span></h1>
        <p>Campus Portal</p>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 320px 1fr; gap: 32px; align-items: start; margin-top: 24px;">
      <div class="dash-panel-left" style="width: 100%;">
        <div class="dash-card">
          <h2 class="dash-card-header">Your Profile</h2>
          <div class="profile-info">
            <div class="info-row">
              <span class="info-label">Name</span>
              <span class="info-value"><%= profile.fullName %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><%= isStaff ? 'Staff ID' : 'Student ID' %></span>
              <span class="info-value"><%= profile.campusId %></span>
            </div>
            <div class="info-row">
              <span class="info-label">Role</span>
              <span class="role-badge <%= isStaff ? 'staff' : '' %>"><%= role %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="dash-panel-right" style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: start;">
        <div class="dash-card" style="grid-column: span 2;">
          <h2 class="dash-card-header">Quick Access</h2>
          <div class="quick-access-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
            <% if (isStaff || profile.role === 'Admin') { %>
              <a href="/admin/helpdesk" class="qa-item staff">
                <div class="qa-icon">🛟</div>
                <span class="qa-text">IT Helpdesk</span>
              </a>
              <a href="/forum" class="qa-item staff">
                <div class="qa-icon">💬</div>
                <span class="qa-text">Forum</span>
              </a>
              <a href="/feedback" class="qa-item staff">
                <div class="qa-icon">📝</div>
                <span class="qa-text">Feedback</span>
              </a>
              <a href="/room-booking" class="qa-item staff">
                <div class="qa-icon">📅</div>
                <span class="qa-text">Room Booking</span>
              </a>
              <a href="/profile" class="qa-item staff">
                <div class="qa-icon">👤</div>
                <span class="qa-text">Profile</span>
              </a>
            <% } else { %>
              <a href="/forum" class="qa-item">
                <div class="qa-icon">💬</div>
                <span class="qa-text">Student Forum</span>
              </a>
              <a href="/room-booking" class="qa-item">
                <div class="qa-icon">📅</div>
                <span class="qa-text">Room Booking</span>
              </a>
              <a href="/feedback" class="qa-item">
                <div class="qa-icon">📝</div>
                <span class="qa-text">Feedback</span>
              </a>
              <a href="/profile" class="qa-item">
                <div class="qa-icon">👤</div>
                <span class="qa-text">Profile</span>
              </a>
            <% } %>
          </div>
        </div>

        <div class="dash-card">
          <h2 class="dash-card-header">Notifications</h2>
          <% if (notifications && notifications.length > 0) { %>
            <ul class="notif-list">
              <% notifications.forEach((n) => { %>
                <li class="notif-item <%= n.type === 'success' ? 'success' : n.type === 'warning' ? 'warning' : '' %>">
                  <div class="notif-icon-wrap">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg>
                  </div>
                  <div class="notif-content">
                    <h4><%= n.title %></h4>
                    <p><%= n.message %></p>
                    <div class="notif-time"><%= n.timeText || 'Just now' %></div>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } else { %>
            <p style="padding: 12px 0; color: #666;">No notifications yet.</p>
          <% } %>
        </div>

        <div class="dash-card">
          <h2 class="dash-card-header">Portal Modules</h2>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <% if (role === 'Student') { %>
              <div class="module-item">
                <div>
                  <h4>Financial Hub</h4>
                  <p>Tuition and fee payments</p>
                </div>
                <a href="/financial" class="btn-module" style="text-decoration: none; display: inline-block;">Open</a>
              </div>
              <div class="module-item">
                <div>
                  <h4>Student Forum</h4>
                  <p>Join campus discussions and announcements</p>
                </div>
                <a href="/forum" class="btn-module" style="text-decoration: none; display: inline-block;">Open</a>
              </div>
              <div class="module-item">
                <div>
                  <h4>My Bookings</h4>
                  <p>View and manage your upcoming reservations.</p>
                </div>
                <a href="/rooms/my-bookings" class="btn-module" style="text-decoration: none; display: inline-block;">Open</a>
              </div>
            <% } %>

            <% if (isStaff) { %>
              <div class="module-item">
                <div>
                  <h4>IT Helpdesk</h4>
                  <p>Manage manual password resets</p>
                </div>
                <a href="/admin/helpdesk" class="btn-module" style="text-decoration: none; display: inline-block;">Open</a>
              </div>
              <div class="module-item">
                <div>
                  <h4>Forum</h4>
                  <p>Access and manage campus-wide discussions</p>
                </div>
                <a href="/forum" class="btn-module" style="text-decoration: none; display: inline-block;">Open</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>