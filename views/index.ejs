<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campus Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <% 
    const isStaff = profile.campusId && profile.campusId.toUpperCase().startsWith('E');
    const role = isStaff ? 'Staff' : 'Student';
    const avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(profile.fullName)}&background=${isStaff ? '8b5cf6' : '3b82f6'}&color=fff&size=128`;
  %>

  <div class="dashboard-container">
    <div class="greeting-banner <%= isStaff ? 'staff-banner' : '' %>">
      <img src="<%= avatarUrl %>" alt="Profile Avatar" class="greeting-avatar">
      <div class="greeting-text">
        <h1>Welcome back, <%= profile.fullName %>! <span class="role-inline">(<%= role %>)</span></h1>
        <p>Campus Portal</p>
      </div>
    </div>

    <div class="dashboard-grid">
      <div>
        <div class="dash-card">
          <h2 class="dash-card-header">Your Profile</h2>
          <div class="profile-info">
            <div class="info-row">
              <span class="info-label">Name</span>
              <span class="info-value"><%= profile.fullName %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><%= isStaff ? 'Staff ID' : 'Student ID' %></span>
              <span class="info-value"><%= profile.campusId %></span>
            </div>
            <div class="info-row">
              <span class="info-label">Role</span>
              <span class="role-badge <%= isStaff ? 'staff' : '' %>"><%= role %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="dashboard-right">
        <div class="dash-card">
          <h2 class="dash-card-header">Quick Access</h2>
          <div class="quick-access-grid">
            <% if (profile.role === 'Admin') { %>
              <a href="/admin/helpdesk" class="qa-item staff">
                <div class="qa-icon">⚙️</div>
                <span class="qa-text">Helpdesk</span>
              </a>
              <a href="/forum" class="qa-item staff">
                <div class="qa-icon">💬</div>
                <span class="qa-text">Forum</span>
              </a>
              <a href="/profile" class="qa-item staff">
                <div class="qa-icon">👤</div>
                <span class="qa-text">Profile</span>
              </a>
            <% } else { %>
              <a href="/forum" class="qa-item">
                <div class="qa-icon">💬</div>
                <span class="qa-text">Student Forum</span>
              </a>
              <a href="/profile" class="qa-item">
                <div class="qa-icon">👤</div>
                <span class="qa-text">Profile</span>
              </a>
              <a href="/admin/helpdesk" class="qa-item">
                <div class="qa-icon">🛠️</div>
                <span class="qa-text">Helpdesk</span>
              </a>
            <% } %>
          </div>
        </div>

        <!-- Campus Events & Notifications Panel -->
<div class="dash-card" style="flex: 1; min-width: 0;">
    <h2 class="dash-card-header">Campus Events & Notifications</h2>
    <ul class="notif-list">
        
        <% if (notifications && notifications.length > 0) { %>
            <% notifications.forEach(notification => { %>
                <li class="notif-item">
                    <!-- Smarter Icon Selection: Checks for 'Event/Seminar' type OR keywords in the title -->
                    <% 
                        const isBlueEvent = notification.type === 'Event' || 
                                            notification.type === 'Seminar' || 
                                            (notification.title && (
                                                notification.title.toLowerCase().includes('hackathon') || 
                                                notification.title.toLowerCase().includes('seminar') || 
                                                notification.title.toLowerCase().includes('house')
                                            ));
                        if (isBlueEvent) { 
                    %>
                        <div class="notif-icon-wrap" style="background-color: #e0f2fe;">
                            <!-- Calendar / Event Icon -->
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0284c7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                        </div>
                    <% } else { %>
                        <div class="notif-icon-wrap" style="background-color: #fef3c7;">
                            <!-- Alert / Notification Icon -->
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                <line x1="12" y1="9" x2="12" y2="13"></line>
                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                            </svg>
                        </div>
                    <% } %>

                    <!-- Dynamic Content from MongoDB -->
                    <div class="notif-content">
    <!-- Clickable Title leading to the specific Event Page -->
                          <a href="/events/<%= notification._id %>" style="text-decoration: none; color: inherit;">
                           <h4 style="margin: 0; color: #1e293b; transition: color 0.2s;" onmouseover="this.style.color='#0284c7'" onmouseout="this.style.color='#1e293b'">
                               <%= notification.title %> ↗
                           </h4>
                        </a>
                        <p><%= notification.description %></p>
                        <!-- Upgraded Meta Info Row -->
                        <div class="notif-time" style="display: flex; gap: 15px; flex-wrap: wrap; margin-top: 6px; color: #64748b;">
                            <span>📅 <%= notification.date ? new Date(notification.date).toLocaleDateString() : 'No Date' %></span>
                            <% if (notification.location) { %>
                                <span>📍 <%= notification.location %></span>
                            <% } %>
                            <% if (notification.organizer) { %>
                                <span>👤 <%= notification.organizer %></span>
                            <% } %>
                        </div>
                    </div>
                </li>
            <% }); %>
        <% } else { %>
            <li class="notif-item">
                <div class="notif-content">
                    <p>No new campus events or notifications right now.</p>
                </div>
            </li>
        <% } %>

    </ul>
</div>

        <div class="dash-card">
          <h2 class="dash-card-header">Portal Modules</h2>
          <div class="module-stack">
            <div class="module-item">
              <div>
                <h4>Academic Records</h4>
                <p>View transcripts and grades</p>
              </div>
              <button class="btn-module" type="button">Open</button>
            </div>
            <div class="module-item">
              <div>
                <h4>Financial Hub</h4>
                <p>Tuition and fee payments</p>
              </div>
              <a href="/financial" class="btn-module" style="text-decoration:none; display:inline-block;">Open</a>
            </div>
            <div class="module-item">
              <div>
                <h4>Course Registration</h4>
                <p>Enroll for next semester</p>
              </div>
              <button class="btn-module" type="button">Open</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>