<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= room.name %> – Availability</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%- include('../partials/navbar') %>

<main class="main-container">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a href="/rooms">All Rooms</a> / <span><%= room.name %></span>
    </div>

    <!-- Flash Messages -->
    <% if (locals.success && success.length > 0) { %>
        <div class="flash flash-success"><%= success %></div>
    <% } %>
    <% if (locals.error && error.length > 0) { %>
        <div class="flash flash-error"><%= error %></div>
    <% } %>

    <div class="two-col">

        <!-- Left: Room Info -->
        <aside class="room-info-card">
            <div class="room-card-accent"></div>
            <div class="room-card-body">
                <h3 class="room-name"><%= room.name %></h3>
                <p class="room-desc"><%= room.description %></p>
                <p class="meta-badge" style="margin-top:0.75rem">👥 Capacity: <strong><%= room.capacity %> pax</strong></p>

                <% if (room.amenities && room.amenities.length > 0) { %>
                    <div class="amenities" style="margin-top:1rem">
                        <% room.amenities.forEach(a => { %>
                            <span class="amenity-tag">✓ <%= a %></span>
                        <% }) %>
                    </div>
                <% } %>

                <!-- Legend -->
                <div class="legend">
                    <h4 class="legend-title">Legend</h4>
                    <div class="legend-item">
                        <div class="legend-dot available-dot"></div><span>Available — click to book</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot booked-dot"></div><span>Already booked</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Right: Availability -->
        <section class="availability-panel">

            <!-- Date Picker -->
            <div class="avail-header">
                <h3 class="section-title">Availability</h3>
                <form method="GET" action="/rooms/<%= room._id %>" class="filter-form">
                    <input type="date" class="input-field input-sm" name="date"
                           value="<%= selectedDate %>"
                           min="<%= new Date().toISOString().split('T')[0] %>" />
                    <button class="btn btn-primary btn-sm" type="submit">View</button>
                </form>
            </div>

            <p class="date-label">Slots for <strong><%= new Date(selectedDate + 'T00:00:00').toDateString() %></strong></p>

            <!-- Slot Grid -->
            <div class="slot-grid">
                <% timeSlots.forEach(slot => { %>
                    <% const isBooked = bookedSlots.includes(slot.start); %>
                    <% if (isBooked) { %>
                        <div class="slot booked">
                            <span class="slot-time"><%= slot.label %></span>
                            <span class="slot-status">Booked</span>
                        </div>
                    <% } else { %>
                        <a href="/rooms/<%= room._id %>/book?date=<%= selectedDate %>&start=<%= slot.start %>"
                           class="slot available">
                            <span class="slot-time"><%= slot.label %></span>
                            <span class="slot-status">Available</span>
                        </a>
                    <% } %>
                <% }) %>
            </div>

            <!-- Bookings Table -->
            <% if (bookings.length > 0) { %>
                <div class="bookings-section">
                    <h4 class="section-title" style="margin-bottom:1rem">Bookings on this day</h4>
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Student</th>
                                    <th>ID</th>
                                    <th>Purpose</th>
                                    <th>Pax</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bookings.forEach(b => { %>
                                    <tr>
                                        <td><span class="time-badge"><%= b.startTime %> – <%= b.endTime %></span></td>
                                        <td><%= b.studentName %></td>
                                        <td><code><%= b.studentId %></code></td>
                                        <td class="text-muted"><%= b.purpose %></td>
                                        <td><%= b.groupSize %></td>
                                        <td>
                                            <form action="/rooms/bookings/<%= b._id %>?_method=DELETE" method="POST"
                                                  onsubmit="return confirm('Cancel this booking?')">
                                                <button class="btn btn-danger btn-sm" type="submit">Cancel</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } %>

        </section>
    </div>
</main>

</body>
</html>
